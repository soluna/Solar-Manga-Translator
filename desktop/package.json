{
  "name": "solar-manga-translator-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop shell for Solar-Manga-Translator",
  "author": "Solar-Manga-Translator contributors",
  "type": "module",
  "main": "main.mjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "stage-runtime": "node ./scripts/stage-runtime.mjs",
    "dist:win": "node ./scripts/package-win.mjs",
    "dist:win:dir": "node ./scripts/package-win.mjs --dir"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.github.soluna.solar-manga-translator",
    "productName": "Solar-Manga-Translator",
    "files": [
      "main.mjs",
      "preload.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources-staging/frontend-dist",
        "to": "frontend-dist"
      },
      {
        "from": "resources-staging/backend-source",
        "to": "backend-source"
      },
      {
        "from": "resources-staging/fonts",
        "to": "fonts"
      },
      {
        "from": "resources-staging/python-runtime",
        "to": "python-runtime"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "Solar-Manga-Translator-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
