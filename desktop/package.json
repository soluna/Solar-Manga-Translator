{
  "name": "manga-translator-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop shell for Manga Translator",
  "author": "Manga Translator contributors",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "stage-runtime": "node ./scripts/stage-runtime.mjs",
    "dist:win": "node ./scripts/package-win.mjs",
    "dist:win:dir": "node ./scripts/package-win.mjs --dir"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "org.mangatranslator.desktop",
    "productName": "Manga Translator",
    "files": [
      "main.mjs",
      "preload.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources-staging/frontend-dist",
        "to": "frontend-dist"
      },
      {
        "from": "resources-staging/backend-source",
        "to": "backend-source"
      },
      {
        "from": "resources-staging/python-runtime",
        "to": "python-runtime"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "MangaTranslator-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
